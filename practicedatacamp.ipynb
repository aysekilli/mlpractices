    "from sklearn.linear_model import LogisticRegression\n",
    "\n",
    "X_train = [[0, 0], [1, 1]]\n",
    "y_train = [0, 1]\n",
    "X_test = [[2, 2], [3, 3], [4, 5], [5, 6],[-1, 0]]\n",
    "\n",
    "\n",
    "model = LogisticRegression()\n",
    "model.fit(X_train, y_train)\n",
    "predictions = model.predict(X_test)\n",
    "print(predictions)"
   ]
